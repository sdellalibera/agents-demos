# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Azure AI Foundry project endpoint
AZURE_FOUNDRY_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>

# Bing Grounding connection resource name from the Foundry portal (used by 04_tool_calls_bing)
BING_CONNECTION_ID=<your-connection-name>
