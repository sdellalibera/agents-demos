# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Azure AI Foundry project endpoint
AZURE_FOUNDRY_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>

# ID of an existing persistent agent (used by 03_call_agent)
# Create one by running 01_persistent_agent without the cleanup step and copying the printed agent ID.
AZURE_FOUNDRY_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx

# Bing Grounding connection resource ID from the Foundry portal (used by 04_tool_calls_bing)
BING_CONNECTION_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>/connections/<connection-name>
